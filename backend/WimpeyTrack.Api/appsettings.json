{
  "ConnectionStrings": {
    "DefaultConnection": "DataSource=app.db;Cache=Shared"
  },
  "OsrmSettings": {
    "BaseUrl": "http://osrm-backend:5000/"
  },
  "VisionService": {
    "BaseUrl": "http://document-vision-service"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureDocumentIntelligence": {
    "Endpoint": "your-azure-intelligence-endpoint",
    "ApiKey": "your-api-key"
  },
  "Reports" : {
    "BasePath": "Reports/"
  }
}
